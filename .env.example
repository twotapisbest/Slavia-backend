# Skopiuj do pliku `.env` w tym katalogu (`cp .env.example .env` / ręcznie).
# Wartości z `.env` mają pierwszeństwo jak przy zwykłych zmiennych środowiskowych.

# --- Reset bazy (jednorazowo) ---
# `true` przy starcie serwera: DROP tabel + CREATE + seed z db.rs. Potem ustaw z powrotem `false`,
# bo inaczej przy każdym uruchomieniu znów wyczyści bazę.
REBUILD_DB=false

# --- Serwer ---
# PORT=8080

# --- Baza danych ---
# Produkcja (Turso, domyślnie): nie ustawiaj DATABASE_MODE albo DATABASE_MODE=turso + URL/token:
# TURSO_DATABASE_URL=libsql://twoja-baza.turso.io
# TURSO_AUTH_TOKEN=
#
# Rozwój lokalny (SQLite w pliku — bez Turso):
# DATABASE_MODE=local
# Opcjonalna ścieżka pliku (domyślnie .local/slavia.db):
# DATABASE_LOCAL_PATH=.local/slavia.db

# --- JWT / Cloudinary (jeśli nie używasz Secrets.toml) ---
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
# JWT_SECRET=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Wymagane dla uploadu unsigned (dziala stabilnie niezaleznie od czasu serwera, np. Render/Leapcell):
# CLOUDINARY_UPLOAD_PRESET=moj_unsigned_preset
# Uwaga: ustaw ten preset jako "Unsigned" w panelu Cloudinary.
# API_KEY/API_SECRET sa nadal potrzebne do operacji uprzywilejowanych (np. destroy).
